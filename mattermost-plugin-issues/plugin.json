{
    "id": "com.mattermost.issues",
    "name": "Issues Tracker",
    "description": "Agile issue tracking with projects, labels, cycles, and priorities — integrated into the Mattermost sidebar.",
    "homepage_url": "https://github.com/mattermost/mattermost-plugin-issues",
    "support_url": "https://github.com/mattermost/mattermost-plugin-issues/issues",
    "icon_path": "assets/icon.svg",
    "version": "0.1.0",
    "min_server_version": "9.0.0",
    "server": {
        "executables": {
            "linux-amd64": "server/dist/plugin-linux-amd64",
            "linux-arm64": "server/dist/plugin-linux-arm64",
            "darwin-amd64": "server/dist/plugin-darwin-amd64",
            "darwin-arm64": "server/dist/plugin-darwin-arm64",
            "windows-amd64": "server/dist/plugin-windows-amd64.exe"
        }
    },
    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    },
    "settings_schema": {
        "header": "Issues Tracker Plugin Settings",
        "footer": "",
        "settings": [
            {
                "key": "AIServiceURL",
                "display_name": "AI Service URL",
                "type": "text",
                "help_text": "URL of the AI analysis service (e.g. http://host.docker.internal:3001).",
                "default": ""
            },
            {
                "key": "AIServiceSecret",
                "display_name": "AI Service Shared Secret",
                "type": "text",
                "help_text": "Shared secret for authenticating requests between the plugin and the AI service.",
                "default": ""
            },
            {
                "key": "OpenAIAPIKey",
                "display_name": "OpenAI API Key",
                "type": "text",
                "help_text": "OpenAI API key used by the AI service for conversation analysis (gpt-4o-mini).",
                "default": ""
            }
        ]
    }
}
